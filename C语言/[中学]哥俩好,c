#include<stdio.h>
int main(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    if(n%2==0){
        for(int i=0,j=n-1;i<j;i++,j--){
            int mul=arr[i]*arr[j];
            printf("%d ",mul);
        }
        printf("\n");
    }
    if(n%2==1){
        for(int i=0,j=n-1;i<j;i++,j--){
            int mul=arr[i]*arr[j];
            printf("%d ",mul);
        }
        printf("%d \n",arr[(n-1)/2]);
    }
    return 0;
}